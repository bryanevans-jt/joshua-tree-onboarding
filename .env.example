# Supabase – required for Vercel deploy (database + template storage)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin sign-in (Google OAuth) – create OAuth 2.0 Client ID in Google Cloud Console:
# APIs & Services → Credentials → Create Credentials → OAuth client ID → Web application.
# Add authorized redirect URI: https://your-domain.com/api/auth/callback/google (and http://localhost:3000/api/auth/callback/google for local).
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx

# NextAuth – use: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Optional: keep Supabase from pausing (Vercel cron hits /api/cron/keep-alive every ~6 days). Set in Vercel so cron requests are authenticated.
CRON_SECRET=

# Gmail – send onboarding completion emails (Nodemailer + App Password)
GMAIL_USER=your-email@yourdomain.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
