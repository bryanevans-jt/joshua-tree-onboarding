# Supabase – required for Vercel deploy (database + template storage)
# Get these from Supabase project: Settings → API. Run the SQL in supabase/migrations/ in the SQL Editor once.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Gmail – send onboarding completion emails (Nodemailer + App Password)
GMAIL_USER=your-email@yourdomain.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
